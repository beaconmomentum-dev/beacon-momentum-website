# =============================================================================
# Beacon Momentum WWW — Environment Variables Reference
# =============================================================================
# Copy this file to .env and fill in the real values before building or running.
# The .env file is gitignored and must NEVER be committed to the repository.
# This .env.example file IS committed and serves as the authoritative reference.
# =============================================================================

# -----------------------------------------------------------------------------
# CLIENT-SIDE (baked into the JS bundle at build time — REQUIRED for build)
# -----------------------------------------------------------------------------

# Manus OAuth portal URL — the subdomain where the member platform lives
VITE_OAUTH_PORTAL_URL=https://app.beaconmomentum.com

# Manus App ID — the identifier registered with Manus OAuth for this app
VITE_APP_ID=beacon-momentum-www

# GoHighLevel API key — used for newsletter/CRM integration
VITE_GHL_API_KEY=pit-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GoHighLevel Location ID — optional, used for location-specific GHL features
VITE_GHL_LOCATION_ID=

# Frontend Forge API — optional, leave blank if not using AI content features
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=

# Analytics (Umami) — optional, leave blank to disable analytics entirely
# If set, BOTH must be set together or neither will be injected into the page
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# -----------------------------------------------------------------------------
# SERVER-SIDE (runtime environment — REQUIRED for the server to start)
# -----------------------------------------------------------------------------

NODE_ENV=production
PORT=3012

# Database connection string (DigitalOcean managed MySQL via private network)
DATABASE_URL=mysql://beacon_app:PASSWORD@10.108.0.2:3306/beacon_momentum

# JWT secret for session signing — must be a long random string
JWT_SECRET=change-me-to-a-long-random-secret

# OAuth server URL — must match VITE_OAUTH_PORTAL_URL
OAUTH_SERVER_URL=https://app.beaconmomentum.com

# Cohort lead dashboard password (shared password for /the-watch/cohort)
COHORT_LEAD_PASSWORD=

# Owner OpenID — optional, used for admin-level auth checks
OWNER_OPEN_ID=

# Backend Forge API — optional, server-side AI content features
BUILT_IN_FORGE_API_KEY=
BUILT_IN_FORGE_API_URL=
